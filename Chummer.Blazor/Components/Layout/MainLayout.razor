@inherits LayoutComponentBase
@inject NavigationManager Navigation

@if (IsHomeRoute())
{
    <DesktopShell />
}
else
{
    <h1 style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;">Chummer Blazor Head</h1>

    <div class="app-frame">
        <header class="app-chrome">
            <div class="app-title">Chummer Blazor Head</div>
            <div class="app-subtitle">Shared presenter workspace shell</div>
        </header>
        <main class="app-content">
            @Body
        </main>
    </div>
}

@code
{
    private bool IsHomeRoute()
    {
        string relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        return string.IsNullOrWhiteSpace(relativePath)
            || string.Equals(relativePath, "/", StringComparison.Ordinal);
    }
}
