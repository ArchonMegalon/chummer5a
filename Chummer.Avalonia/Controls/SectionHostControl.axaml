<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.SectionHostControl">
  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
    <TextBlock Grid.Row="0" x:Name="NoticeText" Text="Notice: Ready." TextWrapping="Wrap" />

    <Border Grid.Row="1" Padding="8" BorderThickness="1" BorderBrush="#4B5563">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
        <TextBlock Grid.Row="0" Text="Active Section Preview" FontWeight="Bold" />
        <ListBox Grid.Row="1" x:Name="SectionRowsList" Height="120" />
        <TextBox Grid.Row="2"
                 x:Name="SectionPreviewBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsReadOnly="True" />
      </Grid>
    </Border>

    <Border Grid.Row="2" BorderThickness="1" BorderBrush="#CBD5E1" Padding="6">
      <StackPanel Spacing="4">
        <TextBlock Text="Raw XML Import (Developer Utility)" FontWeight="Bold" />
        <TextBox x:Name="XmlInputBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="100"
                 Watermark="Optional raw XML payload for diagnostics" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
